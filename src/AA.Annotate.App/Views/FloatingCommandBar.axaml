<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AA.Annotate.App.Views.FloatingCommandBar">
  <Border Height="52"
          Padding="10,8"
          CornerRadius="{StaticResource RadiusLarge}"
          Background="{StaticResource OverlayRestBrush}"
          BorderBrush="{StaticResource OverlayBorderBrush}"
          BorderThickness="1">
    <StackPanel Orientation="Horizontal" Spacing="6">
      <Button Name="MoveButton" Classes="iconButton" Width="36" Height="36" ToolTip.Tip="Move to display">
        <PathIcon Width="20" Height="20" Data="M3,5 L21,5 L21,16 L3,16 Z M5,7 L5,14 L19,14 L19,7 Z M9,18 L15,18 L15,20 L9,20 Z" />
      </Button>
      <Button Name="CaptureButton" Classes="iconButton" Width="36" Height="36" ToolTip.Tip="New capture">
        <PathIcon Width="20" Height="20" Data="M9,4 L15,4 L16.8,6 L20,6 C21.1,6 22,6.9 22,8 L22,19 C22,20.1 21.1,21 20,21 L4,21 C2.9,21 2,20.1 2,19 L2,8 C2,6.9 2.9,6 4,6 L7.2,6 Z M12,9 C9.2,9 7,11.2 7,14 C7,16.8 9.2,19 12,19 C14.8,19 17,16.8 17,14 C17,11.2 14.8,9 12,9 Z M12,11 C13.7,11 15,12.3 15,14 C15,15.7 13.7,17 12,17 C10.3,17 9,15.7 9,14 C9,12.3 10.3,11 12,11 Z" />
      </Button>
      <Button Name="CaptureSelectorButton" Classes="activeIconButton" MinWidth="54" Height="36" ToolTip.Tip="Captures">
        <Grid Height="36" ColumnDefinitions="Auto,10" ColumnSpacing="4" VerticalAlignment="Center">
          <TextBlock Name="CaptureNumberText"
                     Text=""
                     FontSize="18"
                     LineHeight="18"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center"
                     TextAlignment="Center" />
          <PathIcon Grid.Column="1"
                    Width="10"
                    Height="10"
                    VerticalAlignment="Center"
                    Data="M7,9 L12,14 L17,9 Z" />
        </Grid>
      </Button>
      <Button Name="CropButton" Classes="iconButton" Width="36" Height="36" ToolTip.Tip="Crop">
        <PathIcon Width="20" Height="20" Data="M5,3 L7,3 L7,17 L21,17 L21,19 L19,19 L19,23 L17,23 L17,19 L7,19 C5.9,19 5,18.1 5,17 L5,7 L1,7 L1,5 L5,5 Z M9,5 L17,5 C18.1,5 19,5.9 19,7 L19,15 L17,15 L17,7 L9,7 Z" />
      </Button>
      <Button Name="AnnotationButton" Classes="iconButton" Width="36" Height="36" ToolTip.Tip="Annotation box">
        <PathIcon Width="20" Height="20" Data="M4,5 L20,5 C21.1,5 22,5.9 22,7 L22,17 C22,18.1 21.1,19 20,19 L10,19 L6,23 L6,19 L4,19 C2.9,19 2,18.1 2,17 L2,7 C2,5.9 2.9,5 4,5 Z M5,8 L5,16 L19,16 L19,8 Z" />
      </Button>
      <Button Name="FinishButton" Classes="confirmButton" Width="36" Height="36" ToolTip.Tip="Send to agent">
        <PathIcon Width="20" Height="20" Data="M12,2 C6.5,2 2,6.5 2,12 C2,17.5 6.5,22 12,22 C17.5,22 22,17.5 22,12 C22,6.5 17.5,2 12,2 Z M10.2,16.3 L6.7,12.8 L8.1,11.4 L10.2,13.5 L15.9,7.8 L17.3,9.2 Z" />
      </Button>
      <Button Name="CancelButton" Classes="iconButton" Width="36" Height="36" ToolTip.Tip="Cancel">
        <PathIcon Width="19" Height="19" Data="M6.4,5 L12,10.6 L17.6,5 L19,6.4 L13.4,12 L19,17.6 L17.6,19 L12,13.4 L6.4,19 L5,17.6 L10.6,12 L5,6.4 Z" />
      </Button>
    </StackPanel>
  </Border>
</UserControl>
