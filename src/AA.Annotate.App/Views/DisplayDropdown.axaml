<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AA.Annotate.App.Views.DisplayDropdown">
  <Border Width="360"
          Padding="8"
          CornerRadius="{StaticResource RadiusLarge}"
          Background="{StaticResource OverlayRestBrush}"
          BorderBrush="{StaticResource OverlayBorderBrush}"
          BorderThickness="1">
    <Canvas Name="DisplayMap"
            Width="340"
            Height="130" />
  </Border>
</UserControl>
