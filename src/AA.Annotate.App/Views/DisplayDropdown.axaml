<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AA.Annotate.App.Views.DisplayDropdown">
  <Border Name="RootBorder"
          Width="312"
          Padding="7"
          CornerRadius="{StaticResource RadiusLarge}"
          Background="{StaticResource PanelSurfaceBrush}"
          BorderBrush="{StaticResource OverlayBorderBrush}"
          BorderThickness="1">
    <Canvas Name="DisplayMap"
            Width="298"
            Height="112" />
  </Border>
</UserControl>
