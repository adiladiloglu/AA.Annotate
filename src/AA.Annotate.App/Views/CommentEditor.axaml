<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AA.Annotate.App.Views.CommentEditor">
  <Border Padding="10"
          CornerRadius="{StaticResource RadiusMedium}"
          Background="{StaticResource CommentEditorBrush}"
          BorderBrush="{StaticResource OverlayBorderBrush}"
          BorderThickness="1">
    <Grid ColumnDefinitions="360,36,36" ColumnSpacing="8">
      <Border Name="TextHostBorder"
              Classes="commentTextHost"
              MinHeight="36"
              MaxHeight="156">
        <TextBox Name="CommentTextBox"
                 Classes="commentTextBox"
                 Watermark="Comment"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 MinHeight="34"
                 MaxHeight="154" />
      </Border>
      <Button Name="DeleteButton" Grid.Column="1" Classes="iconButton" Width="36" Height="36" ToolTip.Tip="Delete">
        <PathIcon Width="19" Height="19" Data="M8,3 L16,3 L17,5 L21,5 L21,7 L3,7 L3,5 L7,5 Z M5,9 L19,9 L18,21 C17.9,22.1 17.1,23 16,23 L8,23 C6.9,23 6.1,22.1 6,21 Z M9,11 L9,20 L11,20 L11,11 Z M13,11 L13,20 L15,20 L15,11 Z" />
      </Button>
      <Button Name="OkButton" Grid.Column="2" Classes="confirmButton" Width="36" Height="36" ToolTip.Tip="Save">
        <PathIcon Width="20" Height="20" Data="M12,2 C6.5,2 2,6.5 2,12 C2,17.5 6.5,22 12,22 C17.5,22 22,17.5 22,12 C22,6.5 17.5,2 12,2 Z M10.2,16.3 L6.7,12.8 L8.1,11.4 L10.2,13.5 L15.9,7.8 L17.3,9.2 Z" />
      </Button>
    </Grid>
  </Border>
</UserControl>
